---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  canonicalUrl?: string;
  ogImage?: string;
  jsonLd?: Record<string, unknown>;
}

const {
  title,
  description = 'Download videos from YouTube, Instagram, TikTok, Facebook and more — free, fast, no signup.',
  canonicalUrl,
  ogImage,
  jsonLd,
} = Astro.props;

const canonical = canonicalUrl ?? Astro.url.href;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#0a0a0f" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- OpenGraph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    {ogImage && <meta property="og:image" content={ogImage} />}

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {ogImage && <meta name="twitter:image" content={ogImage} />}

    <!-- JSON-LD -->
    {jsonLd && (
      <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    )}

    <!-- Extra head content (per-page JSON-LD, etc.) -->
    <slot name="head" />
  </head>

  <body class="bg-grid scanlines min-h-screen flex flex-col" style="background-color: var(--color-bg-base); color: var(--color-text-primary);">

    <!-- Nav -->
    <nav style="background-color: var(--color-bg-surface); border-bottom: 1px solid var(--color-border-default);" class="sticky top-0 z-50">
      <div class="max-w-6xl mx-auto px-4 h-14 flex items-center justify-between">
        <a href="/" class="flex items-center gap-2 no-underline group">
          <span class="text-2xl font-bold tracking-tight" style="font-family: var(--font-mono); color: var(--color-neon-purple-bright);">
            V<span style="color: var(--color-text-primary);">Down</span>
          </span>
          <span class="text-xs px-1.5 py-0.5 rounded" style="background-color: var(--color-bg-overlay); color: var(--color-neon-purple); border: 1px solid var(--color-border-neon); font-family: var(--font-mono);">
            VIDEO
          </span>
        </a>

        <nav class="hidden md:flex items-center gap-6 text-sm" style="color: var(--color-text-secondary);">
          <a href="/download/youtube" class="hover:text-white transition-colors" style="color: inherit;">YouTube</a>
          <a href="/download/instagram" class="hover:text-white transition-colors" style="color: inherit;">Instagram</a>
          <a href="/download/tiktok" class="hover:text-white transition-colors" style="color: inherit;">TikTok</a>
          <a href="/blog" class="hover:text-white transition-colors" style="color: inherit;">Blog</a>
        </nav>
      </div>
    </nav>

    <!-- Page content -->
    <main class="flex-1">
      <slot />
    </main>

    <!-- Footer -->
    <footer style="background-color: var(--color-bg-surface); border-top: 1px solid var(--color-border-default);">
      <div class="max-w-6xl mx-auto px-4 py-8">
        <div class="flex flex-col md:flex-row items-center justify-between gap-4 text-sm" style="color: var(--color-text-muted);">
          <span style="font-family: var(--font-mono);">© {new Date().getFullYear()} VDown Video — Download responsibly.</span>
          <div class="flex gap-6">
            <a href="/blog" style="color: inherit;" class="hover:text-white transition-colors">Blog</a>
            <a href="/download/youtube" style="color: inherit;" class="hover:text-white transition-colors">YouTube</a>
            <a href="/download/instagram" style="color: inherit;" class="hover:text-white transition-colors">Instagram</a>
            <a href="/download/tiktok" style="color: inherit;" class="hover:text-white transition-colors">TikTok</a>
          </div>
        </div>
      </div>
    </footer>

  </body>
</html>
