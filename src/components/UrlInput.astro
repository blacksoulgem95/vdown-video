---
interface Props {
  initialUrl?: string;
  placeholder?: string;
}

const { initialUrl = '', placeholder = 'Paste a video URL — YouTube, Instagram, TikTok, Facebook…' } = Astro.props;
---

<div id="url-input-container" class="w-full">
  <form id="url-form" class="flex flex-col gap-3" novalidate>
    <div class="relative">
      <input
        id="url-input"
        type="url"
        value={initialUrl}
        placeholder={placeholder}
        autocomplete="off"
        autocorrect="off"
        spellcheck={false}
        class="w-full px-4 py-4 rounded-lg text-base outline-none transition-all duration-200 border-neon-pulse"
        style="
          background-color: var(--color-bg-elevated);
          color: var(--color-text-primary);
          font-family: var(--font-mono);
          font-size: 0.875rem;
        "
        aria-label="Video URL"
      />
      <!-- Loading spinner (hidden by default) -->
      <div
        id="url-spinner"
        class="absolute right-4 top-1/2 -translate-y-1/2 hidden"
        aria-hidden="true"
      >
        <div
          class="w-5 h-5 rounded-full border-2"
          style="
            border-color: var(--color-neon-purple) transparent var(--color-neon-purple) transparent;
            animation: spin 0.8s linear infinite;
          "
        ></div>
      </div>
    </div>

    <!-- Inline error -->
    <p
      id="url-error"
      class="hidden text-sm px-1"
      style="color: var(--color-error); font-family: var(--font-mono);"
      role="alert"
    ></p>

    <button
      type="submit"
      id="url-submit"
      class="w-full py-3 rounded-lg font-semibold text-sm transition-all duration-200 glow-purple"
      style="
        background-color: var(--color-neon-purple);
        color: #ffffff;
        font-family: var(--font-mono);
        letter-spacing: 0.05em;
      "
    >
      ANALYSE URL
    </button>
  </form>
</div>

<script>
  const form = document.getElementById('url-form') as HTMLFormElement;
  const input = document.getElementById('url-input') as HTMLInputElement;
  const spinner = document.getElementById('url-spinner') as HTMLDivElement;
  const errorEl = document.getElementById('url-error') as HTMLParagraphElement;
  const submitBtn = document.getElementById('url-submit') as HTMLButtonElement;

  function showError(msg: string): void {
    errorEl.textContent = msg;
    errorEl.classList.remove('hidden');
  }

  function clearError(): void {
    errorEl.textContent = '';
    errorEl.classList.add('hidden');
  }

  function setLoading(loading: boolean): void {
    spinner.classList.toggle('hidden', !loading);
    submitBtn.disabled = loading;
    submitBtn.textContent = loading ? 'ANALYSING…' : 'ANALYSE URL';
    input.disabled = loading;
  }

  function isValidUrl(url: string): boolean {
    try {
      const parsed = new URL(url);
      return parsed.protocol === 'http:' || parsed.protocol === 'https:';
    } catch {
      return false;
    }
  }

  // Auto-submit if initialUrl is provided (from ?url= query param)
  if (input.value && isValidUrl(input.value)) {
    form.dispatchEvent(new Event('submit', { bubbles: true, cancelable: true }));
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    clearError();

    const url = input.value.trim();

    if (!url) {
      showError('Please paste a video URL.');
      return;
    }

    if (!isValidUrl(url)) {
      showError('That doesn\'t look like a valid URL. Try https://…');
      return;
    }

    setLoading(true);

    try {
      const res = await fetch('/api/metadata', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ url }),
      });

      const data = await res.json() as Record<string, unknown>;

      if (!res.ok) {
        showError((data['error'] as string | undefined) ?? 'Could not fetch video info. Is the URL public?');
        return;
      }

      window.dispatchEvent(new CustomEvent('metadata-loaded', { detail: { url, ...data } }));
    } catch {
      showError('Network error. Check your connection and try again.');
    } finally {
      setLoading(false);
    }
  });
</script>
