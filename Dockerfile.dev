# ─────────────────────────────────────────────────────────────
# VDown Video — Development Image
# Hot-reload enabled. Mount src/ as volume for live editing.
# ─────────────────────────────────────────────────────────────
FROM node:20-bookworm

# System deps: ffmpeg + python3 (for yt-dlp)
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
      ffmpeg \
      python3 \
      python3-pip && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

# yt-dlp + gallery-dl
RUN pip3 install --no-cache-dir yt-dlp gallery-dl

WORKDIR /app
COPY package.json package-lock.json ./
RUN npm ci
COPY . .

# Mount points (created so the container starts even if volumes are empty)
RUN mkdir -p /app/data/sqlite /app/data/cache /app/data/cms

# Env
ENV PORT=4321
ENV NODE_ENV=development

EXPOSE ${PORT}

# Dev mode — astro dev with hot reload
CMD ["npm", "run", "dev", "--", "--host"]
